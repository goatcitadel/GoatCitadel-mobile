{
  "expo": {
    "name": "GoatCitadel",
    "slug": "goatcitadel-mobile",
    "version": "0.1.3",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "goatcitadel",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06080d"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06080d"
      },
      "package": "com.goatcitadel.mobile",
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.goatcitadel.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "GoatCitadel uses your photos so you can attach images to chat.",
          "cameraPermission": "GoatCitadel uses your camera so you can take a picture and ask GoatCitadel about what you see."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GoatCitadel uses your location while the app is open so nearby questions can use your current area."
        }
      ],
      "./plugins/with-lan-network-security",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-image",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
