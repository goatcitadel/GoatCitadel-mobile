{
  "name": "goatcitadel-mobile",
  "version": "0.1.3",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:doctor": "node scripts/android-emulator-doctor.mjs",
    "android:avd:list": "node scripts/android-emulator-doctor.mjs --list-avds",
    "android:emulator:start": "node scripts/android-emulator-start.mjs",
    "android:install:apk": "node scripts/android-install-apk.mjs",
    "android:proof:handoff": "node scripts/android-proof-handoff.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:apk": "set NODE_ENV=production&& set ANDROID_HOME=F:\\Android\\Sdk&& set ANDROID_SDK_ROOT=F:\\Android\\Sdk&& cd android && gradlew.bat assembleRelease && cd .. && copy /Y android\\app\\build\\outputs\\apk\\release\\app-release.apk GoatCitadel.apk",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/rajdhani": "^0.4.1",
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "*",
    "@goatcitadel/contracts": "0.6.0-beta.2",
    "@gorhom/bottom-sheet": "*",
    "@shopify/flash-list": "2.0.2",
    "buffer": "^6.0.3",
    "expo": "~55.0.5",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.8",
    "expo-blur": "~55.0.9",
    "expo-build-properties": "*",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "*",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "*",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "*",
    "expo-location": "~55.1.2",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-secure-store": "*",
    "expo-speech": "~55.0.8",
    "expo-splash-screen": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "punycode": "^2.3.1",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "*",
    "react-native-markdown-display": "*",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
